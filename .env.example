# =============================================================================
# Climate Action — root .env for Docker Compose (DigitalOcean deployment)
# Copy this file to .env and fill in real values before running docker-compose
# =============================================================================

# --- API Gateway ---
GATEWAY_PORT=8080
AUTH_SERVICE_URL=http://auth-service:8081
COUNT_EMISSION_SERVICE_ADDR=count-emission-service:50051
NOTIFICATION_SERVICE_ADDR=notification-service:50052
CONVERT_EMISSION_SERVICE_ADDR=convert-emission-service:50053
GRPC_USE_TLS=false

# --- Auth Service ---
AUTH_PORT=8081
AUTH_DB_URL=postgresql://<user>:<password>@<supabase-host>:5432/auth_db?sslmode=require

# --- JWT (shared between api-gateway and auth-service) ---
JWT_SECRET=your-strong-random-secret-at-least-32-chars
JWT_EXPIRY=24h

# --- Count Emission Service ---
EMISSION_GRPC_PORT=50051
DB_HOST=<supabase-host>
DB_PORT=5432
DB_USER=<user>
DB_PASSWORD=<password>
DB_NAME=emission_db
DB_SCHEMA=public
DB_SSLMODE=require
RAPID_API_KEY=<carbonsutra-rapidapi-key>
CARBON_TOKEN=<carbon-interface-bearer-token>

# --- Notification Service ---
NOTIFICATION_GRPC_PORT=50052

# --- Convert Emission Service ---
CONVERT_GRPC_PORT=50053
MONGO_URI=mongodb+srv://<user>:<password>@<atlas-cluster>/climate_action_masterdata?retryWrites=true&w=majority
